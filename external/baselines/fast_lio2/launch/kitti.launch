<launch>
  <param name="use_sim_time" value="true" />

  <!-- Load FAST-LIO2 velodyne config, then override for KITTI HDL-64E -->
  <rosparam command="load" file="$(find fast_lio)/config/velodyne.yaml" />

  <!-- KITTI HDL-64E overrides -->
  <param name="preprocess/scan_line" type="int" value="64" />
  <param name="preprocess/blind" type="double" value="2.0" />
  <param name="publish/path_en" type="bool" value="true" />
  <param name="pcd_save/pcd_save_en" type="bool" value="false" />
  <!-- Do NOT override mapping/extrinsic_T here. kitti.yaml carries the real
       KITTI Raw calib (~0.8 m LiDAR-IMU offset). A zero override was a
       SUP-01 regression caught by scripts/audit_baseline_configs.py. -->

  <node pkg="fast_lio" type="fastlio_mapping" name="laserMapping"
        output="screen" respawn="false">
  </node>
</launch>
