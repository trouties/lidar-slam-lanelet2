<launch>
  <param name="use_sim_time" value="true" />

  <!-- hdl_graph_slam nodelet manager -->
  <node pkg="nodelet" type="nodelet" name="hdl_graph_slam_manager"
        args="manager" output="screen" />

  <!-- Prefiltering: downsample + range filter -->
  <node pkg="nodelet" type="nodelet" name="prefiltering_nodelet"
        args="load hdl_graph_slam/PrefilteringNodelet hdl_graph_slam_manager">
    <remap from="/velodyne_points" to="/velodyne_points" />
    <param name="base_link_frame" value="velodyne" />
    <param name="use_distance_filter" value="true" />
    <param name="distance_near_thresh" value="5.0" />
    <param name="distance_far_thresh" value="100.0" />
    <param name="downsample_method" value="VOXELGRID" />
    <param name="downsample_resolution" value="0.2" />
  </node>

  <!-- Scan matching odometry -->
  <node pkg="nodelet" type="nodelet" name="scan_matching_odometry_nodelet"
        args="load hdl_graph_slam/ScanMatchingOdometryNodelet hdl_graph_slam_manager">
    <param name="odom_frame_id" value="odom" />
    <param name="robot_odom_frame_id" value="velodyne" />
    <param name="keyframe_delta_trans" value="2.0" />
    <param name="keyframe_delta_angle" value="0.5" />
    <param name="registration_method" value="NDT_OMP" />
    <param name="ndt_resolution" value="1.0" />
    <param name="ndt_num_threads" value="4" />
  </node>

  <!-- Graph-based SLAM -->
  <node pkg="nodelet" type="nodelet" name="hdl_graph_slam_nodelet"
        args="load hdl_graph_slam/HdlGraphSlamNodelet hdl_graph_slam_manager"
        output="screen">
    <param name="map_frame_id" value="map" />
    <param name="odom_frame_id" value="odom" />

    <!-- Loop closure -->
    <param name="enable_loop_closure" value="true" />
    <param name="distance_thresh" value="30.0" />
    <param name="accum_distance_thresh" value="15.0" />
    <param name="min_edge_interval" value="30" />
    <param name="fitness_score_thresh" value="2.0" />

    <!-- Graph optimization -->
    <param name="g2o_solver_type" value="lm_var" />
    <param name="g2o_solver_num_iterations" value="512" />
    <param name="graph_update_interval" value="3.0" />

    <!-- Disable GPS / IMU / floor -->
    <param name="enable_gps" value="false" />
    <param name="enable_imu" value="false" />
    <param name="enable_floor" value="false" />
  </node>
</launch>
